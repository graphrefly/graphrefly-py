---
const base = import.meta.env.BASE_URL;
---

<div class="gr-home not-content">
	<!-- ══ HERO ══ -->
	<section class="gr-hero">
		<div class="gr-hero-bg" aria-hidden="true">
			<div class="gr-orb gr-orb-aqua"></div>
			<div class="gr-orb gr-orb-gold"></div>
			<div class="gr-orb gr-orb-purple"></div>

			<div class="gr-hero-lines">
				<svg viewBox="0 0 1440 900" preserveAspectRatio="none">
					<defs>
						<linearGradient id="gr-grad-aqua" x1="0%" y1="0%" x2="100%" y2="100%">
							<stop offset="0%" stop-color="rgba(0,212,232,.6)" />
							<stop offset="100%" stop-color="rgba(0,212,232,0)" />
						</linearGradient>
						<linearGradient id="gr-grad-warm" x1="0%" y1="100%" x2="100%" y2="0%">
							<stop offset="0%" stop-color="rgba(0,168,192,.5)" />
							<stop offset="100%" stop-color="rgba(0,168,192,0)" />
						</linearGradient>
						<linearGradient id="gr-grad-purple" x1="100%" y1="0%" x2="0%" y2="100%">
							<stop offset="0%" stop-color="rgba(64,120,136,.4)" />
							<stop offset="100%" stop-color="rgba(64,120,136,0)" />
						</linearGradient>
					</defs>
					<path class="gr-flow-line gr-fl-1" d="M-50,350 C200,300 350,500 550,380 C750,260 900,450 1150,320 C1300,240 1400,350 1500,300" />
					<path class="gr-flow-line gr-fl-2" d="M-50,550 C150,500 300,650 500,520 C700,390 850,580 1100,480 C1250,420 1380,530 1500,470" />
					<path class="gr-flow-line gr-fl-3" d="M-50,200 C180,180 320,280 480,220 C640,160 800,300 1000,230 C1200,160 1350,250 1500,200" />
					<path class="gr-flow-line gr-fl-4" d="M-50,450 C200,420 380,550 580,470 C780,390 950,500 1180,430 C1320,380 1420,450 1500,420" />
					<path class="gr-flow-line gr-fl-5" d="M-50,150 C150,130 280,200 420,170 C560,140 720,250 900,200 C1080,150 1250,220 1500,180" />
				</svg>
			</div>
		</div>

		<div class="gr-hero-vertical gr-hero-vertical-left" aria-hidden="true">观其流而知其源</div>
		<div class="gr-hero-vertical gr-hero-vertical-right" aria-hidden="true">应于务亦留其迹</div>

		<div class="gr-hero-content">
			<p class="gr-kicker">Reactive Harness Layer</p>
			<h1 class="gr-title">Graph<span class="gr-title-re">Re</span>Fly<span class="gr-title-dot">.</span></h1>
			<p class="gr-subtitle">state that flows</p>
			<p class="gr-tagline">The harness layer between your LLM and production — reactive, resumable, causally explainable.</p>
			<div class="gr-hero-cta">
				<div class="gr-hero-row gr-hero-row--install">
					<div class="gr-install-box">
						<code class="gr-install-cmd" translate="no">pip install graphrefly</code>
						<button type="button" class="gr-install-copy" aria-label="Copy install command">
							<span class="gr-install-copy-label">Copy</span>
						</button>
					</div>
					<a
						href="https://github.com/graphrefly/graphrefly-py"
						class="gr-btn gr-btn-ghost gr-hero-gh"
						target="_blank"
						rel="noopener noreferrer">graphrefly-py</a>
				</div>
				<div class="gr-hero-row gr-hero-row--cta">
					<a href={`${base}spec/`} class="gr-btn gr-btn-primary">Read the Spec</a>
					<a href="#implementations" class="gr-btn gr-btn-ghost">More Implementations</a>
				</div>
			</div>
		</div>
	</section>

	<!-- Sine divider: hero → philosophy -->
	<div class="gr-ripple-divider" aria-hidden="true">
		<svg viewBox="0 0 1440 60" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="none">
			<path d="M0,30 C180,10 360,50 540,30 C720,10 900,50 1080,30 C1260,10 1350,40 1440,30 L1440,60 L0,60 Z" fill="#080a0c" />
			<path d="M0,30 C180,10 360,50 540,30 C720,10 900,50 1080,30 C1260,10 1350,40 1440,30" fill="none" stroke="#00d4e8" stroke-width="0.8" opacity="0.1" />
		</svg>
	</div>

	<!-- ══ PHILOSOPHY ══ -->
	<section class="gr-philosophy">
		<div class="gr-container">
			<div class="gr-phil-stroke" aria-hidden="true"></div>
			<div class="gr-phil-body">
				<p class="gr-section-label">Philosophy</p>
				<blockquote class="gr-phil-quote">Stream flows, light glows - insight without interference</blockquote>
				<p class="gr-phil-translation">川流不息，光影自浮</p>
				<p class="gr-phil-text">
					Data moves with relentless precision, yet its velocity demands a deeper, quieter clarity.
					We embrace the art of <strong>non-intrusive observation</strong>&mdash;capturing the essence of the stream
					without ever diverting its natural course. By allowing swift reactions to be
					<strong>snapshotted, persisted, and resumed</strong> at will, we transform ephemeral code into
					<strong>enduring, modular graphs</strong>.
					This creates a shared reality where <strong>structural integrity meets liquid speed</strong>, allowing
					<strong>humans and AI to cooperate</strong> on a single, transparent foundation. This is the simple alchemy of our
					protocol: <strong>Graph + Reactive = Fly</strong>.
				</p>
			</div>
		</div>
	</section>

	<!-- Sine divider: philosophy → features -->
	<div class="gr-ripple-divider gr-ripple-up" aria-hidden="true">
		<svg viewBox="0 0 1440 60" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="none">
			<path d="M0,30 C240,12 480,48 720,30 C960,12 1200,48 1440,30 L1440,60 L0,60 Z" fill="#080a0c" />
			<path d="M0,30 C240,12 480,48 720,30 C960,12 1200,48 1440,30" fill="none" stroke="#00a8c0" stroke-width="0.6" opacity="0.07" />
		</svg>
	</div>

	<!-- ══ FEATURES ══ -->
	<section class="gr-features-section">
		<div class="gr-container">
			<p class="gr-section-label">Four Pillars</p>
			<h2 class="gr-features-heading">The harness beneath the flow</h2>
			<div class="gr-features-grid">
				<div class="gr-feature-card" data-accent="warm" data-reveal>
					<div class="gr-feature-coord"><span class="gr-marker"><svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2L2 12l10 10 10-10Z"/></svg></span> N01 &middot; ENGINE</div>
					<h3>Reactive Precision</h3>
					<p>A harness protocol small enough for an LLM to reason about, yet robust enough to eliminate race conditions through a rigorous <strong>two-phase push</strong> mechanism. Every flow is glitch-free, high-performance, and <strong>diamond-safe</strong> — the deterministic foundation your agent needs.</p>
				</div>
				<div class="gr-feature-card" data-accent="aqua" data-reveal>
					<div class="gr-feature-coord"><span class="gr-marker"><svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2L2 12l10 10 10-10Z"/></svg></span> N02 &middot; CONTRACT</div>
					<h3>Governed Integrity</h3>
					<p>Trust is not an add-on; it is the harness. With <strong>ABAC</strong> policy enforcement and <strong>causal tracing</strong> baked into every node, every state change is authorized, auditable, and explainable. Ask "why was this flagged?" — get a structural causal chain, not a log dump.</p>
				</div>
				<div class="gr-feature-card" data-accent="purple" data-reveal>
					<div class="gr-feature-coord"><span class="gr-marker"><svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2L2 12l10 10 10-10Z"/></svg></span> N03 &middot; VISION</div>
					<h3>Living Blueprints</h3>
					<p>Moving from ephemeral code to <strong>persistent, inspectable artifacts</strong>. Describe workflows declaratively via <strong>GraphSpec</strong> — like SQL for data flows. LLMs compose structurally, humans review visually. Every checkpoint is resumable, every decision is traceable.</p>
				</div>
				<div class="gr-feature-card" data-accent="pink" data-reveal>
					<div class="gr-feature-coord"><span class="gr-marker"><svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2L2 12l10 10 10-10Z"/></svg></span> N04 &middot; FUTURE</div>
					<h3>Agentic Co-operation</h3>
					<p>The harness layer where <strong>humans describe intent</strong> and <strong>LLMs compose the graph</strong>. By unifying policy enforcement, causal observability, and persistent checkpoints, GraphReFly is the reactive harness between your LLM and production&mdash;making agent workflows resumable and causally explainable.</p>
				</div>
			</div>
		</div>
	</section>

	<!-- Sine divider: features → code -->
	<div class="gr-ripple-divider" aria-hidden="true">
		<svg viewBox="0 0 1440 60" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="none">
			<path d="M0,30 C144,14 288,46 432,30 C576,14 720,46 864,30 C1008,14 1152,46 1296,30 C1368,22 1404,38 1440,30 L1440,60 L0,60 Z" fill="#080a0c" />
			<path d="M0,30 C144,14 288,46 432,30 C576,14 720,46 864,30 C1008,14 1152,46 1296,30 C1368,22 1404,38 1440,30" fill="none" stroke="#00d4e8" stroke-width="0.7" opacity="0.08" />
		</svg>
	</div>

	<!-- ══ CODE PREVIEW ══ -->
	<section class="gr-code-section">
		<div class="gr-container">
			<p class="gr-section-label">Quick Taste</p>
			<div class="gr-code-block">
				<div class="gr-code-header">
					<div class="gr-code-dots"><span class="gr-code-dot"></span><span class="gr-code-dot"></span><span class="gr-code-dot"></span></div>
					<span>example.py</span>
				</div>
				<div class="gr-code-body">
					<pre><code><span class="kw">count</span> <span class="punct">=</span> <span class="fn">state</span><span class="punct">(</span><span class="num">0</span><span class="punct">)</span>
<span class="kw">doubled</span> <span class="punct">=</span> <span class="fn">derived</span><span class="punct">([</span>count<span class="punct">],</span> <span class="kw">lambda</span> c<span class="punct">:</span> c <span class="punct">*</span> <span class="num">2</span><span class="punct">)</span>
<span class="fn">effect</span><span class="punct">([</span>doubled<span class="punct">],</span> <span class="kw">lambda</span> d<span class="punct">:</span> <span class="fn">print</span><span class="punct">(</span>d<span class="punct">))</span>

count<span class="punct">.</span><span class="fn">down</span><span class="punct">([(</span><span class="str">DATA</span><span class="punct">,</span> <span class="num">1</span><span class="punct">)])</span>  <span class="cmt"># prints: 2</span></code></pre>
				</div>
			</div>
		</div>
	</section>

	<!-- Sine divider: code → use cases -->
	<div class="gr-ripple-divider gr-ripple-up" aria-hidden="true">
		<svg viewBox="0 0 1440 60" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="none">
			<path d="M0,30 C180,12 360,48 540,30 C720,12 900,48 1080,30 C1260,12 1350,42 1440,30 L1440,60 L0,60 Z" fill="#080a0c" />
			<path d="M0,30 C180,12 360,48 540,30 C720,12 900,48 1080,30 C1260,12 1350,42 1440,30" fill="none" stroke="#407888" stroke-width="0.5" opacity="0.06" />
		</svg>
	</div>

	<!-- ══ USE CASES ══ -->
	<section class="gr-use-cases-section">
		<div class="gr-container">
			<p class="gr-section-label">Where the harness leads</p>
			<h2 class="gr-features-heading">Built for the workflows ahead</h2>
			<div class="gr-use-cases-wrap">
				<div class="gr-use-cases-streams" aria-hidden="true">
					<svg viewBox="0 0 1100 220" preserveAspectRatio="xMidYMid meet">
						<path d="M60,110 C180,60 280,160 400,110 C520,60 620,160 740,110" stroke="rgba(0,212,232,.12)" stroke-width="1.5" fill="none" />
						<path d="M360,110 C480,50 580,170 700,110 C820,50 920,170 1040,110" stroke="rgba(0,168,192,.08)" stroke-width="1" fill="none" />
						<path d="M-20,130 C100,80 220,180 340,120 C460,60 580,160 700,100 C820,40 940,140 1120,90" stroke="rgba(64,120,136,.06)" stroke-width="0.8" fill="none" />
					</svg>
				</div>
				<div class="gr-use-cases-grid">
					<div class="gr-use-card" data-reveal>
						<span class="gr-use-card-glyph">
							<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1 0 2.83 2 2 0 0 1-2.83 0l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-2 2 2 2 0 0 1-2-2v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83 0 2 2 0 0 1 0-2.83l.06-.06a1.65 1.65 0 0 0 .33-1.82 1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1-2-2 2 2 0 0 1 2-2h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 0-2.83 2 2 0 0 1 2.83 0l.06.06a1.65 1.65 0 0 0 1.82.33H9a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 2-2 2 2 0 0 1 2 2v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 0 2 2 0 0 1 0 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82V9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 2 2 2 2 0 0 1-2 2h-.09a1.65 1.65 0 0 0-1.51 1z"/></svg>
						</span>
						<h4>Orchestration</h4>
						<p>Reactive, resumable multi-step agent pipelines.</p>
					</div>
					<div class="gr-use-card" data-reveal>
						<span class="gr-use-card-glyph">
							<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M8 3 4 7l4 4"/><path d="M4 7h16"/><path d="m16 21 4-4-4-4"/><path d="M20 17H4"/></svg>
						</span>
						<h4>Message Queue</h4>
						<p>Buffered, back-pressured message passing.</p>
					</div>
					<div class="gr-use-card" data-reveal>
						<span class="gr-use-card-glyph">
							<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M4 15s1-1 4-1 5 2 8 2 4-1 4-1V3s-1 1-4 1-5-2-8-2-4 1-4 1z"/><line x1="4" y1="22" x2="4" y2="15"/></svg>
						</span>
						<h4>AI Agentic Memory</h4>
						<p>Persistent, causally traceable state for LLM agents.</p>
					</div>
					<div class="gr-use-card" data-reveal>
						<span class="gr-use-card-glyph">
							<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10"/><path d="M12 11a2 2 0 1 0 0-4 2 2 0 0 0 0 4z"/><path d="M12 11v3"/></svg>
						</span>
						<h4>Policy & Audit</h4>
						<p>ABAC enforcement and causal audit trails in every node.</p>
					</div>
					<div class="gr-use-card" data-reveal>
						<span class="gr-use-card-glyph">
							<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M17 8h1a4 4 0 1 1 0 8h-1"/><path d="M3 8h14v9a4 4 0 0 1-4 4H7a4 4 0 0 1-4-4Z"/><line x1="6" y1="2" x2="6" y2="4"/><line x1="10" y1="2" x2="10" y2="4"/><line x1="14" y1="2" x2="14" y2="4"/></svg>
						</span>
						<h4>Human + AI Ops</h4>
						<p>Shared graphs for real-time co-operation.</p>
					</div>
				</div>
			</div>
		</div>
	</section>

	<!-- Sine divider: use cases → impl -->
	<div class="gr-ripple-divider" aria-hidden="true">
		<svg viewBox="0 0 1440 60" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="none">
			<path d="M0,30 C240,14 480,46 720,30 C960,14 1200,46 1440,30 L1440,60 L0,60 Z" fill="#080a0c" />
			<path d="M0,30 C240,14 480,46 720,30 C960,14 1200,46 1440,30" fill="none" stroke="#00a8c0" stroke-width="0.5" opacity="0.06" />
		</svg>
	</div>

	<!-- ══ IMPLEMENTATIONS CTA ══ -->
	<section class="gr-impl-cta" id="implementations">
		<p class="gr-section-label">Implementations</p>
		<div class="gr-impl-cards">
			<div class="gr-impl-card">
				<h3>graphrefly-py</h3>
				<p class="gr-impl-lang">Python</p>
				<div class="gr-impl-actions">
					<a href="https://github.com/graphrefly/graphrefly-py" class="gr-btn gr-btn-impl" target="_blank" rel="noopener noreferrer">View on GitHub</a>
					<button
						type="button"
						class="gr-btn gr-btn-ghost gr-impl-cmd gr-impl-cmd--py"
						data-copy-text="pip install graphrefly"
						data-default-label="pip install graphrefly"
						aria-label="Copy Python install command">pip install graphrefly</button>
				</div>
			</div>
			<div class="gr-impl-divider" aria-hidden="true"></div>
			<div class="gr-impl-card">
				<h3>graphrefly-ts</h3>
				<p class="gr-impl-lang">TypeScript</p>
				<div class="gr-impl-actions">
					<a href="https://github.com/graphrefly/graphrefly-ts" class="gr-btn gr-btn-impl" target="_blank" rel="noopener noreferrer">View on GitHub</a>
					<button
						type="button"
						class="gr-btn gr-btn-ghost gr-impl-cmd gr-impl-cmd--ts"
						data-copy-text="npm i @graphrefly/graphrefly"
						data-default-label="npm i @graphrefly/graphrefly"
						aria-label="Copy TypeScript install command">npm i @graphrefly/graphrefly</button>
				</div>
			</div>
		</div>
	</section>
</div>

<style is:global>
	/* ── GraphReFly Home — A-water-ink ── */

	/* Break out of Starlight's content wrapper */
	.sl-markdown-content:has(.gr-home) {
		max-width: 100% !important;
	}
	.content-panel:has(.gr-home) {
		max-width: 100% !important;
		padding: 0 !important;
	}
	.content-panel:has(.gr-home) .sl-container {
		max-width: 100% !important;
		padding: 0 !important;
	}
	/* Hide Starlight splash hero block when `hero` frontmatter is used */
	.content-panel:has(.gr-home) .hero {
		display: none;
	}

	.gr-home {
		--gr-ink: #050508;
		--gr-ink-deep: #030306;
		--gr-ink-raised: #080a0c;
		--gr-aqua: #00d4e8;
		--gr-aqua-dim: #00a8c0;
		--gr-warm: #5a9aaa;
		--gr-stone: #7a9caa;
		--gr-parchment: #d8e4e8;
		--gr-purple: #0098b0;
		--gr-pink: #60a8e0;
		--gr-serif: 'Noto Serif SC', serif;
		--gr-sans: 'Source Sans 3', sans-serif;
		--gr-mono: 'JetBrains Mono', monospace;
		color: var(--gr-parchment);
		font-family: var(--gr-sans);
		font-weight: 400;
		line-height: 1.7;
		max-width: none;
		width: 100%;
	}
	.gr-home a { color: inherit; text-decoration: none; }

	/* ── HERO ── */
	.gr-hero {
		position: relative;
		min-height: 100vh;
		display: flex;
		align-items: center;
		justify-content: center;
		overflow: hidden;
	}
	.gr-hero-bg {
		position: absolute; inset: 0; z-index: 0;
	}

	/* Orbs */
	.gr-orb {
		position: absolute;
		border-radius: 50%;
		filter: blur(100px);
		will-change: transform;
	}
	.gr-orb-aqua {
		width: 500px; height: 500px;
		background: rgba(0,212,232,.12);
		top: 8%; left: 12%;
		animation: gr-float-a 24s ease-in-out infinite;
	}
	.gr-orb-gold {
		width: 400px; height: 400px;
		background: rgba(0,168,192,.08);
		top: 52%; right: 14%;
		animation: gr-float-b 28s ease-in-out infinite;
	}
	.gr-orb-purple {
		width: 350px; height: 350px;
		background: rgba(64,120,136,.06);
		bottom: 15%; left: 45%;
		animation: gr-float-c 22s ease-in-out infinite;
	}
	@keyframes gr-float-a {
		0%, 100% { transform: translate(0,0) scale(1); }
		33% { transform: translate(60px,-40px) scale(1.1); }
		66% { transform: translate(-30px,50px) scale(.95); }
	}
	@keyframes gr-float-b {
		0%, 100% { transform: translate(0,0) scale(1); }
		25% { transform: translate(-50px,30px) scale(1.08); }
		50% { transform: translate(40px,-60px) scale(.92); }
		75% { transform: translate(-20px,-20px) scale(1.05); }
	}
	@keyframes gr-float-c {
		0%, 100% { transform: translate(0,0) scale(1); }
		40% { transform: translate(50px,40px) scale(1.12); }
		70% { transform: translate(-40px,-30px) scale(.9); }
	}

	/* SVG flow lines */
	.gr-hero-lines {
		position: absolute; inset: 0; z-index: 1;
		pointer-events: none; opacity: .5;
	}
	.gr-hero-lines svg { width: 100%; height: 100%; }
	.gr-flow-line {
		fill: none;
		stroke-width: 2.5;
		stroke-linecap: round;
		stroke-dasharray: 1600;
		stroke-dashoffset: 1600;
	}
	.gr-fl-1 { stroke: url(#gr-grad-aqua); animation: gr-draw 4s ease forwards .5s; }
	.gr-fl-2 { stroke: url(#gr-grad-warm); animation: gr-draw 4s ease forwards 1s; stroke-width: 3; }
	.gr-fl-3 { stroke: url(#gr-grad-purple); animation: gr-draw 4s ease forwards 1.5s; stroke-width: 2; }
	.gr-fl-4 { stroke: url(#gr-grad-aqua); animation: gr-draw 4s ease forwards 1.8s; stroke-width: 1.5; opacity: .5; }
	.gr-fl-5 { stroke: url(#gr-grad-warm); animation: gr-draw 4s ease forwards 2.1s; stroke-width: 1; opacity: .4; }
	@keyframes gr-draw { to { stroke-dashoffset: 0; } }

	/* Vertical decorative text */
	.gr-hero-vertical {
		position: absolute; z-index: 2;
		writing-mode: vertical-rl;
		font-family: var(--gr-serif);
		font-size: .8rem;
		letter-spacing: .5em;
		color: rgba(0,212,232,.12);
		user-select: none;
	}
	.gr-hero-vertical-left { left: 2rem; top: 30%; }
	.gr-hero-vertical-right { right: 2rem; top: 38%; }

	/* Hero content */
	.gr-hero-content {
		position: relative; z-index: 3;
		max-width: 900px;
		text-align: center;
		padding: 4.5rem 2rem 4rem;
	}
	.gr-kicker {
		font-size: .75rem;
		font-weight: 600;
		letter-spacing: .25em;
		text-transform: uppercase;
		color: var(--gr-aqua);
		margin-bottom: 1.5rem;
		opacity: 0;
		animation: gr-fadeUp .8s ease forwards .3s;
	}
	.gr-hero-content .gr-title {
		font-family: var(--gr-serif);
		font-weight: 900;
		font-size: clamp(3rem, 8vw, 6rem);
		line-height: 1.05;
		margin: 0 0 .5rem;
		color: var(--gr-parchment);
		opacity: 0;
		animation: gr-fadeUp .8s ease forwards .5s;
	}
	.gr-title-re {
		background: linear-gradient(135deg, var(--gr-aqua), #38bdf8);
		-webkit-background-clip: text;
		-webkit-text-fill-color: transparent;
		background-clip: text;
	}
	.gr-title-dot { color: var(--gr-warm); }
	.gr-subtitle {
		font-family: var(--gr-serif);
		font-size: 1.15rem;
		color: rgba(90,154,170,.75);
		letter-spacing: .12em;
		font-style: italic;
		margin: 0 0 2rem;
		opacity: 0;
		animation: gr-fadeUp .8s ease forwards .65s;
	}
	.gr-tagline {
		font-size: 1.25rem;
		font-weight: 300;
		line-height: 1.6;
		color: var(--gr-parchment);
		margin: 0 0 2.5rem;
		opacity: 0;
		animation: gr-fadeUp .8s ease forwards .85s;
	}
	.gr-hero-cta {
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 1.25rem;
		width: 100%;
		max-width: 32rem;
		margin-inline: auto;
		opacity: 0;
		animation: gr-fadeUp .8s ease forwards 1s;
	}
	.gr-hero-row {
		display: flex;
		flex-wrap: wrap;
		gap: 0.75rem;
		justify-content: center;
		align-items: stretch;
		width: 100%;
	}
	.gr-hero-row--install {
		align-items: stretch;
	}
	.gr-hero-row--cta {
		align-items: center;
	}
	.gr-install-box {
		display: flex;
		align-items: stretch;
		flex: 1 1 12rem;
		min-width: 0;
		max-width: 22rem;
		border-radius: 6px;
		background: rgba(0, 0, 0, 0.35);
		border: 1px solid rgba(0, 212, 232, 0.12);
		overflow: hidden;
	}
	.gr-install-box .gr-install-cmd {
		display: block;
		flex: 1;
		margin: 0;
		padding: 0.65rem 0.85rem;
		border: none;
		background: transparent;
		font-family: var(--gr-mono);
		font-size: 0.8rem;
		font-weight: 500;
		color: var(--gr-parchment);
		letter-spacing: 0.02em;
		text-align: start;
		min-width: 0;
		overflow: hidden;
		text-overflow: ellipsis;
		white-space: nowrap;
	}
	.gr-install-copy {
		flex: 0 0 6.5rem;
		width: 6.5rem;
		min-width: 6.5rem;
		padding: 0 6px;
		border: none;
		border-left: 1px solid rgba(0, 212, 232, 0.12);
		background: rgba(0, 212, 232, 0.06);
		color: var(--gr-parchment);
		font-size: 0.7rem;
		font-weight: 600;
		letter-spacing: 0.08em;
		text-transform: uppercase;
		cursor: pointer;
		font-family: var(--gr-sans);
		transition: background 0.2s ease, color 0.2s ease;
	}
	.gr-install-copy:hover,
	.gr-install-copy:focus-visible {
		color: var(--gr-parchment);
		background: rgba(0, 212, 232, 0.08);
		outline: none;
	}
	.gr-hero-gh {
		flex: 0 0 auto;
		min-width: 10rem;
		justify-content: center;
	}
	@keyframes gr-fadeUp {
		from { opacity: 0; transform: translateY(16px); }
		to { opacity: 1; transform: translateY(0); }
	}

	/* ── BUTTONS ── */
	.gr-btn {
		display: inline-flex;
		align-items: center;
		gap: .5rem;
		padding: .75rem 1.75rem;
		border-radius: 6px;
		font-family: var(--gr-sans);
		font-size: .875rem;
		font-weight: 600;
		letter-spacing: .04em;
		transition: all .25s;
		cursor: pointer;
		border: none;
		text-decoration: none;
	}
	.gr-btn-primary {
		background: var(--gr-aqua);
		color: var(--gr-ink);
	}
	.gr-home .gr-btn.gr-btn-primary:hover,
	.gr-home .gr-btn.gr-btn-primary:focus-visible {
		background: #30e8f8;
		box-shadow: 0 0 30px rgba(0,212,232,.3);
		color: var(--gr-ink-deep);
	}
	.gr-btn-ghost {
		background: transparent;
		color: var(--gr-parchment);
		border: 1px solid rgba(0,212,232,.18);
	}
	.gr-btn-ghost:hover {
		border-color: rgba(0,212,232,.4);
		background: rgba(0,212,232,.06);
	}
	/* Implementation cards — same visual weight as each other */
	.gr-btn-impl {
		background: rgba(0,212,232,.14);
		color: var(--gr-parchment);
		border: 1px solid rgba(0,212,232,.32);
	}
	.gr-btn-impl:hover {
		background: rgba(0,212,232,.22);
		border-color: rgba(0,212,232,.45);
		color: var(--gr-parchment);
		box-shadow: 0 0 24px rgba(0,212,232,.12);
	}

	/* ── RIPPLE DIVIDERS ── */
	.gr-ripple-divider {
		width: 100%; overflow: hidden;
		line-height: 0; pointer-events: none;
		display: block;
		margin-bottom: -1px;
	}
	.gr-ripple-divider svg { width: 100%; height: auto; display: block; vertical-align: top; }
	.gr-ripple-up { transform: scaleY(-1); margin-bottom: -1px; }

	/* ── SECTIONS SHARED ──
	   No top padding; modest bottom padding so bands sit closer (ripple still separates). */
	.gr-home > section:not(.gr-hero) {
		padding: 0 2rem 3.25rem;
	}
	.gr-container { max-width: 1100px; margin: 0 auto; }
	.gr-section-label {
		font-size: .7rem;
		font-weight: 600;
		letter-spacing: .25em;
		text-transform: uppercase;
		color: var(--gr-aqua);
		margin-bottom: 1rem;
	}

	/* ── PHILOSOPHY ── */
	.gr-philosophy {
		position: relative; overflow: hidden;
		background: var(--gr-ink-raised);
	}
	.gr-philosophy .gr-container {
		display: flex; gap: 4rem; align-items: center;
	}
	.gr-phil-stroke {
		width: 3px; min-height: 300px; flex-shrink: 0;
		background: linear-gradient(to bottom, transparent, var(--gr-warm), transparent);
		border-radius: 2px;
	}
	.gr-phil-body { max-width: 700px; }
	.gr-phil-quote {
		font-family: var(--gr-serif);
		font-size: clamp(1.8rem, 4vw, 2.8rem);
		font-weight: 700;
		line-height: 1.4;
		margin-bottom: .75rem;
		color: var(--gr-parchment);
	}
	.gr-phil-translation {
		font-size: 1.1rem;
		color: var(--gr-warm);
		font-style: italic;
		margin-bottom: 2rem;
	}
	.gr-phil-text {
		font-size: 1rem;
		color: var(--gr-stone);
		line-height: 1.8;
		max-width: 600px;
	}
	.gr-phil-text strong {
		color: var(--gr-parchment);
		font-weight: 600;
	}

	/* ── FEATURES ── */
	.gr-features-section { background: var(--gr-ink); }
	.gr-features-heading {
		font-family: var(--gr-serif);
		font-size: clamp(1.5rem, 3.5vw, 2.2rem);
		font-weight: 700;
		margin-bottom: .5rem;
		color: var(--gr-parchment);
	}
	.gr-features-grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(min(100%, 260px), 1fr));
		gap: 1.5rem;
		margin-top: 1.5rem;
		align-items: stretch;
		align-content: start;
		justify-items: stretch;
	}
	.gr-feature-card {
		position: relative;
		display: flex;
		flex-direction: column;
		min-height: 100%;
		height: 100%;
		box-sizing: border-box;
		background: rgba(8,10,12,.7);
		border: 1px solid rgba(0,212,232,.08);
		border-radius: 10px;
		padding: 1.8rem 1.6rem;
		overflow: hidden;
		cursor: default;
		/* Opacity-only reveal: translateY on grid items misaligns siblings during / after stagger */
		opacity: 0;
		transform: none;
		transition:
			opacity 0.45s ease-out,
			box-shadow 0.25s ease,
			border-color 0.25s ease,
			transform 0.25s ease;
	}
	.gr-feature-card.visible {
		opacity: 1;
	}
	.gr-feature-card:hover {
		box-shadow: 0 16px 40px rgba(0,0,0,.25);
		border-color: rgba(0,212,232,.12);
		transform: translateY(-4px);
	}
	.gr-feature-card.visible:hover {
		transform: translateY(-4px);
	}
	.gr-feature-card::before {
		content: '';
		position: absolute;
		top: -50%; right: -50%;
		width: 200%; height: 200%;
		background: radial-gradient(ellipse at 70% 30%, rgba(0,212,232,.02), transparent 50%);
		pointer-events: none;
	}
	.gr-feature-card::after {
		content: '';
		position: absolute;
		left: 0; top: 10%; bottom: 10%;
		width: 3px;
		border-radius: 3px;
	}
	.gr-feature-card[data-accent="warm"]::after { background: var(--gr-warm); }
	.gr-feature-card[data-accent="aqua"]::after { background: var(--gr-aqua); }
	.gr-feature-card[data-accent="purple"]::after { background: var(--gr-purple); }
	.gr-feature-card[data-accent="pink"]::after { background: var(--gr-pink); }
	.gr-feature-coord {
		font-family: var(--gr-mono);
		font-size: .62rem;
		letter-spacing: .15em;
		color: var(--gr-stone);
		margin-bottom: 1rem;
		display: flex;
		align-items: center;
		gap: .4rem;
	}
	.gr-marker { font-size: .55rem; }
	.gr-feature-card[data-accent="warm"] .gr-marker { color: var(--gr-warm); }
	.gr-feature-card[data-accent="aqua"] .gr-marker { color: var(--gr-aqua); }
	.gr-feature-card[data-accent="purple"] .gr-marker { color: var(--gr-purple); }
	.gr-feature-card[data-accent="pink"] .gr-marker { color: var(--gr-pink); }
	.gr-feature-card h3 {
		font-family: var(--gr-serif);
		font-size: 1.1rem;
		font-weight: 600;
		margin: 0 0 .6rem;
		letter-spacing: -.01em;
		color: var(--gr-parchment);
	}
	.gr-feature-card p {
		font-size: .88rem;
		color: var(--gr-stone);
		line-height: 1.65;
		margin: 0;
		flex: 1;
		min-height: 0;
	}
	.gr-feature-card p strong {
		color: var(--gr-aqua);
		font-weight: 600;
	}

	/* ── CODE PREVIEW ── */
	.gr-code-section { background: var(--gr-ink-raised); }
	.gr-code-block {
		max-width: 700px;
		margin: 1.25rem auto 0;
		background: rgba(5,5,8,.8);
		border: 1px solid rgba(0,212,232,.1);
		border-radius: 10px;
		overflow: hidden;
		font-family: var(--gr-mono);
		font-size: .875rem;
		line-height: 1.8;
	}
	.gr-code-header {
		display: flex;
		align-items: center;
		gap: 6px;
		padding: .75rem 1.25rem;
		background: rgba(0,212,232,.04);
		border-bottom: 1px solid rgba(0,168,192,.08);
	}
	.gr-code-dots { display: flex; gap: 6px; }
	.gr-code-dot {
		width: 10px; height: 10px;
		border-radius: 50%;
		background: rgba(216,228,232,.1);
		margin-top: 0 !important;
		margin-bottom: 0 !important;
	}
	.gr-code-dot:nth-child(1) { background: rgba(0,212,232,.5); }
	.gr-code-dot:nth-child(2) { background: rgba(0,168,192,.5); }
	.gr-code-dot:nth-child(3) { background: rgba(64,120,136,.5); }
	.gr-code-header span {
		margin-left: auto;
		font-size: .7rem;
		color: var(--gr-stone);
		letter-spacing: .08em;
		margin-top: 0 !important;
		margin-bottom: 0 !important;
	}
	.gr-code-body {
		padding: 1.5rem 1.75rem;
		overflow-x: auto;
		margin-top: 0 !important;
	}
	.gr-code-body pre {
		margin: 0;
		padding: 0;
		background: transparent;
		border: none;
		box-shadow: none;
	}
	.gr-code-body .kw { color: var(--gr-purple); }
	.gr-code-body .fn { color: #40e8f8; }
	.gr-code-body .str { color: var(--gr-aqua); }
	.gr-code-body .num { color: var(--gr-warm); }
	.gr-code-body .cmt { color: rgba(140,160,175,.85); font-style: italic; }
	.gr-code-body .punct { color: var(--gr-stone); }

	/* ── USE CASES ── */
	.gr-use-cases-section { background: var(--gr-ink); position: relative; overflow: hidden; }
	.gr-use-cases-wrap { position: relative; margin-top: 1.5rem; }
	.gr-use-cases-streams { position: absolute; inset: 0; pointer-events: none; z-index: 0; }
	.gr-use-cases-streams svg { width: 100%; height: 100%; }
	.gr-use-cases-grid {
		position: relative; z-index: 1;
		display: flex;
		flex-wrap: wrap;
		gap: 2rem;
		justify-content: center;
		align-items: flex-start;
	}
	.gr-use-card {
		width: 180px; min-height: 120px;
		padding: 1.25rem 1.75rem;
		background: rgba(8,10,12,.75);
		border: 1px solid rgba(0,212,232,.1);
		border-radius: 999px;
		display: flex;
		flex-direction: column;
		align-items: center;
		justify-content: center;
		text-align: center;
		box-shadow: 0 0 30px rgba(0,212,232,.04), 0 8px 32px rgba(0,0,0,.3);
		opacity: 0;
		transform: translateY(14px);
		--gr-reveal-delay: 0s;
		transition:
			opacity .35s ease var(--gr-reveal-delay),
			transform .35s ease var(--gr-reveal-delay),
			border-color .2s ease,
			box-shadow .2s ease;
	}
	.gr-use-card:nth-child(even) { margin-top: 3.5rem; }
	.gr-use-card.visible { opacity: 1; transform: translateY(0); }
	.gr-use-card:nth-child(even).visible { transform: translateY(0); }
	.gr-use-card:hover {
		border-color: rgba(0,212,232,.25);
		box-shadow: 0 0 28px rgba(0,212,232,.08), 0 10px 28px rgba(0,0,0,.28);
		transform: translateY(-6px);
	}
	.gr-use-card:nth-child(even):hover { transform: translateY(-6px); }
	.gr-use-card-glyph {
		font-size: 1.3rem;
		margin-bottom: .4rem;
		display: block;
		filter: grayscale(.2);
	}
	.gr-use-card h4 {
		font-family: var(--gr-serif);
		font-size: .85rem;
		font-weight: 600;
		margin: 0 0 .3rem;
		line-height: 1.2;
		color: var(--gr-parchment);
	}
	.gr-use-card p {
		font-size: .68rem;
		color: var(--gr-stone);
		line-height: 1.5;
		margin: 0;
	}
	@media (max-width: 768px) {
		.gr-use-card { width: 140px; padding: 1.25rem 1rem; }
		.gr-use-card h4 { font-size: .8rem; }
		.gr-use-cases-streams { display: none; }
	}

	/* ── IMPLEMENTATIONS CTA (override shared section padding) ── */
	.gr-home > section.gr-impl-cta {
		text-align: center;
		padding: 0 2rem clamp(2.25rem, 5vw, 3.5rem);
		background: var(--gr-ink-raised);
	}
	.gr-impl-cards {
		display: flex;
		flex-direction: row;
		flex-wrap: nowrap;
		align-items: stretch;
		justify-content: center;
		gap: 2rem;
		max-width: 820px;
		margin: 1.25rem auto 0;
	}
	.gr-impl-divider {
		width: 3px;
		flex-shrink: 0;
		align-self: stretch;
		background: linear-gradient(to bottom, transparent, var(--gr-warm), transparent);
		border-radius: 2px;
	}
	.gr-impl-card {
		flex: 1 1 0;
		display: flex;
		flex-direction: column;
		align-items: center;
		justify-content: flex-start;
		min-width: 0;
		width: auto;
		box-sizing: border-box;
		padding: 2.25rem 1.75rem;
		background: rgba(8,10,12,.6);
		border: 1px solid rgba(0,212,232,.06);
		border-radius: 12px;
		text-align: center;
		transition: border-color .3s, box-shadow .3s;
	}
	.gr-impl-card:hover {
		border-color: rgba(0,212,232,.15);
		box-shadow: 0 12px 40px rgba(0,0,0,.25);
	}
	.gr-impl-card h3 {
		font-family: var(--gr-serif);
		font-size: 1.15rem;
		font-weight: 600;
		margin: 0 0 .4rem;
		color: var(--gr-parchment);
	}
	.gr-impl-lang {
		font-family: var(--gr-mono);
		font-size: .7rem;
		letter-spacing: .1em;
		color: var(--gr-stone);
		margin-bottom: 0;
		text-transform: uppercase;
	}
	.gr-impl-actions {
		margin-top: auto;
		width: 100%;
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 0.65rem;
		padding-top: 1.25rem;
	}
	.gr-impl-actions .gr-btn {
		width: 100%;
		max-width: 280px;
		justify-content: center;
	}
	.gr-impl-cmd {
		font-family: var(--gr-mono);
		font-size: 0.78rem;
		font-weight: 500;
		letter-spacing: 0.02em;
		padding: 0.65rem 1rem !important;
	}
	.gr-impl-cmd--py {
		color: var(--gr-warm);
		border-color: rgba(64, 120, 136, 0.28);
	}
	.gr-impl-cmd--py:hover {
		border-color: rgba(64, 120, 136, 0.45);
		background: rgba(64, 120, 136, 0.06);
		color: #90b8c0;
	}
	.gr-impl-cmd--ts {
		color: var(--gr-aqua);
		border-color: rgba(0, 212, 232, 0.28);
	}
	.gr-impl-cmd--ts:hover {
		border-color: rgba(0, 212, 232, 0.45);
		background: rgba(0, 212, 232, 0.08);
		color: #40e8f8;
	}

	/* ── RESPONSIVE ── */
	@media (max-width: 768px) {
		.gr-hero-vertical { display: none; }
		.gr-hero-content { padding: 3rem 1rem 3rem; max-width: 100%; }
		.gr-hero-content .gr-title { font-size: clamp(2.4rem, 10vw, 3.5rem); }
		.gr-tagline { font-size: 1rem; margin-bottom: 2rem; }
		.gr-kicker { font-size: 0.65rem; }

		.gr-hero-cta { max-width: 100%; }
		.gr-hero-row { flex-direction: column; align-items: stretch; }
		.gr-install-box { max-width: 100%; flex: 1 1 auto; }
		.gr-hero-gh { min-width: auto; }
		.gr-hero-row--cta { flex-direction: row; }
		.gr-hero-row--cta .gr-btn { flex: 1 1 0; padding: 0.65rem 1rem; font-size: 0.8rem; text-align: center; justify-content: center; }

		.gr-philosophy .gr-container { flex-direction: column; gap: 2rem; }
		.gr-phil-stroke { min-height: 3px; width: 80px; height: 3px; }
		.gr-phil-quote { font-size: clamp(1.4rem, 5vw, 2rem); }
		.gr-phil-text { font-size: 0.9rem; }

		.gr-features-heading { font-size: clamp(1.3rem, 4vw, 1.8rem); }
		.gr-feature-card { padding: 1.4rem 1.2rem; }
		.gr-feature-card p { font-size: 0.82rem; }

		.gr-code-block { font-size: 0.75rem; }
		.gr-code-body { padding: 1rem 1.25rem; }

		.gr-use-cases-grid { gap: 1rem; }
		.gr-use-card { width: 140px; padding: 1.25rem 1rem; }
		.gr-use-card h4 { font-size: .8rem; }
		.gr-use-card:nth-child(even) { margin-top: 0; }
		.gr-use-cases-streams { display: none; }

		.gr-home > section:not(.gr-hero) { padding: 0 1rem 3rem; }
		.gr-impl-cards {
			flex-direction: column;
			flex-wrap: wrap;
			gap: 1.5rem;
		}
		.gr-impl-divider {
			width: 80%;
			max-width: 200px;
			height: 3px;
			min-height: 0;
			margin-inline: auto;
		}
		.gr-impl-card { padding: 1.75rem 1.25rem; }
	}

	/* Small phones */
	@media (max-width: 400px) {
		.gr-hero-content { padding: 2.5rem 0.75rem 2.5rem; }
		.gr-hero-content .gr-title { font-size: 2.2rem; }
		.gr-hero-row--cta { flex-direction: column; }
		.gr-hero-row--cta .gr-btn { flex: none; }
		.gr-feature-card { padding: 1.2rem 1rem; }
		.gr-code-body { padding: 0.75rem 1rem; }
		.gr-code-body pre { font-size: 0.7rem; }
		.gr-use-card { width: 120px; padding: 1rem 0.75rem; }
	}
</style>

<script>
	// IntersectionObserver for reveal animations
	const reveals = document.querySelectorAll('[data-reveal]');
	if ('IntersectionObserver' in window) {
		const io = new IntersectionObserver((entries) => {
			entries.forEach((entry) => {
				if (entry.isIntersecting) {
					entry.target.classList.add('visible');
					io.unobserve(entry.target);
				}
			});
		}, { threshold: 0.15, rootMargin: '0px 0px -40px 0px' });
		let useCardStagger = 0;
		reveals.forEach((el) => {
			const h = el as HTMLElement;
			/* Stagger only use-case pills — feature cards share a row; Y translate caused misalignment */
			if (el.classList.contains('gr-use-card')) {
				h.style.setProperty('--gr-reveal-delay', `${(useCardStagger++ % 5) * 0.08}s`);
			} else {
				h.style.setProperty('--gr-reveal-delay', '0s');
			}
			io.observe(el);
		});
	} else {
		reveals.forEach((el) => el.classList.add('visible'));
	}

	// Header background on scroll (Starlight wraps the bar in `header.header`)
	const header = document.querySelector('.page > header.header') as HTMLElement | null;
	if (header) {
		window.addEventListener('scroll', () => {
			if (window.scrollY > 60) {
				header.style.background = 'rgba(5,5,8,.88)';
			} else {
				header.style.background = '';
			}
		}, { passive: true });
	}

	document.querySelectorAll('.gr-install-copy').forEach((btn) => {
		btn.addEventListener('click', async () => {
			const box = btn.closest('.gr-install-box');
			const code = box?.querySelector('.gr-install-cmd');
			const text = code?.textContent?.trim() ?? '';
			if (!text) return;
			try {
				await navigator.clipboard.writeText(text);
				const lab = btn.querySelector('.gr-install-copy-label');
				if (lab) {
					const prev = lab.textContent;
					lab.textContent = 'Copied!';
					setTimeout(() => {
						lab.textContent = prev ?? 'Copy';
					}, 1600);
				}
			} catch {
				/* ignore */
			}
		});
	});

	document.querySelectorAll('.gr-impl-cmd[data-copy-text]').forEach((el) => {
		el.addEventListener('click', async () => {
			const btn = el as HTMLButtonElement;
			const text = btn.dataset.copyText?.trim() ?? '';
			if (!text) return;
			try {
				await navigator.clipboard.writeText(text);
				const defaultLabel = btn.dataset.defaultLabel ?? btn.textContent ?? '';
				btn.textContent = 'Copied!';
				window.setTimeout(() => {
					btn.textContent = defaultLabel;
				}, 1500);
			} catch {
				/* ignore */
			}
		});
	});

	document.querySelectorAll('.gr-home a[href^="#"]').forEach((el) => {
		el.addEventListener('click', (e) => {
			const href = el.getAttribute('href');
			if (!href || href.length < 2) return;
			const target = document.querySelector(href);
			if (!(target instanceof HTMLElement)) return;
			e.preventDefault();
			target.scrollIntoView({ behavior: 'smooth', block: 'start' });
		});
	});
</script>
